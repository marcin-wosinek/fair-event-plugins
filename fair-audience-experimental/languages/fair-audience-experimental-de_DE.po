msgid "Fair Audience Experimental"
msgstr "Fair Audience Experimental"

#. Plugin URI of the plugin
#: fair-audience-experimental.php
msgid "https://github.com/marcin-wosinek/fair-event-plugins"
msgstr ""

#. Description of the plugin
#: fair-audience-experimental.php
msgid "Activates advanced feature bundles for Fair Audience (fees, polls, galleries, Instagram, groups, collaborators, messaging, image templates, timeline, import, weekly schedule, invitations, manage-event-ext). Requires fair-audience."
msgstr "Aktiviert erweiterte Funktionspakete für Fair Audience (Gebühren, Umfragen, Galerien, Instagram, Gruppen, Mitarbeiter, Messaging, Bildvorlagen, Zeitleiste, Import, Wochenplan, Einladungen, manage-event-ext). Erfordert fair-audience."

#. Author of the plugin
#: fair-audience-experimental.php
msgid "Marcin Wosinek"
msgstr ""

#. Author URI of the plugin
#: fair-audience-experimental.php
msgid "https://github.com/marcin-wosinek"
msgstr ""

#: fair-audience-experimental.php:37
msgid "Fair Audience Experimental requires the Fair Audience plugin to be active."
msgstr "Fair Audience Experimental erfordert, dass das Fair Audience Plugin aktiv ist."

