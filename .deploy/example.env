# Per-environment deploy config for `npm run deploy:local`.
# Copy to `.deploy/<env>.env` (e.g. `.deploy/staging.env`) and fill in real values.
# These files are gitignored — never commit them.

# SSH connection
SSH_HOST=example.com
SSH_PORT=22
SSH_USER=deploy
# Optional: path to SSH private key. Omit to use the default ssh-agent identity.
# SSH_KEY_PATH=~/.ssh/id_ed25519

# Absolute path on the remote host to the WordPress `wp-content/plugins` directory.
WORDPRESS_PLUGINS_PATH=/var/www/example.com/wp-content/plugins

# Plugins to deploy: comma-separated list, or `all` for fair-events,fair-payment,fair-audience.
PLUGINS_TO_DEPLOY=fair-events,fair-payment,fair-audience
