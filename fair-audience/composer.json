{
	"name": "marcin-wosinek/fair-audience",
	"description": "Fair Audience WordPress plugin",
	"type": "wordpress-plugin",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "Marcin Wosinek",
			"email": "marcin.wosinek@gmail.com"
		}
	],
	"repositories": [
		{
			"type": "path",
			"url": "../fair-events-shared/php",
			"options": {
				"symlink": false
			}
		}
	],
	"require": {
		"php": ">=8.0 <9.0",
		"phpoffice/phpspreadsheet": "^5.8",
		"maennchen/zipstream-php": "^2.1 || ^3.0",
		"fair-events/shared": "^0.1"
	},
	"config": {
		"platform": {
			"php": "8.3"
		}
	},
	"autoload": {
		"psr-4": {
			"FairAudience\\": "src/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	}
}
