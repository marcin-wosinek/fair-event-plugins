{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "fair-audience/fair-form-multiselect",
	"version": "1.0.0",
	"title": "Multiselect Question",
	"category": "widgets",
	"icon": "yes-alt",
	"description": "A multiple-choice checkbox question for Fair Form",
	"keywords": ["question", "checkbox", "multiselect", "multiple"],
	"textdomain": "fair-audience",
	"parent": ["fair-audience/fair-form"],
	"supports": {
		"html": false
	},
	"attributes": {
		"questionText": {
			"type": "string",
			"default": ""
		},
		"questionKey": {
			"type": "string",
			"default": ""
		},
		"required": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./editor.js",
	"render": "file:./render.php",
	"style": "file:./style-editor.css"
}
