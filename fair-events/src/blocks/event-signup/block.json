{
	"apiVersion": 3,
	"name": "fair-events/event-signup",
	"title": "Event Signup",
	"category": "widgets",
	"icon": "tickets-alt",
	"description": "Let visitors sign up or get tickets for an event date. Extends to a participant-aware flow when fair-audience is active.",
	"textdomain": "fair-events",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"padding": true,
			"margin": ["top", "bottom"]
		}
	},
	"attributes": {
		"eventDateId": {
			"type": "integer",
			"default": 0
		},
		"submitButtonText": {
			"type": "string",
			"default": "Get Tickets"
		},
		"isEditorPreview": {
			"type": "boolean",
			"default": false
		}
	},
	"editorScript": "file:./editor.js",
	"editorStyle": "file:./editor.css",
	"viewScript": "file:./frontend.js",
	"style": ["wp-block-button", "file:./frontend.css"],
	"render": "file:./render.php"
}
