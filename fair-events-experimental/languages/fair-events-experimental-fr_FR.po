#: src/Admin/manage-event/EventTickets.js:2124
msgid "Short name"
msgstr "Nom court"

#: src/Admin/manage-event/EventTickets.js:2222
msgid "No discount"
msgstr "Pas de réduction"

#: src/Admin/manage-event/EventTickets.js:2351
msgid "Add participants"
msgstr "Ajouter des participants"

#: src/Admin/manage-event/EventTickets.js:2408
msgid "+ Add Option"
msgstr "+ Ajouter une option"

#: src/Admin/manage-event/EventTickets.js:2418
msgid "Settings"
msgstr "Paramètres"

#: src/Admin/manage-event/EventTickets.js:2423
msgid "Continues pricing period"
msgstr "Période de tarification continue"

#: src/Admin/manage-event/EventTickets.js:2436
msgid "Unlimited tickets in pricing period"
msgstr "Billets illimités dans la période de tarification"

#: src/Admin/manage-event/EventTickets.js:2452
msgid "Per-ticket-type capacity"
msgstr "Capacité par type de billet"

#: src/Admin/manage-event/EventTickets.js:2456
msgid "Show a Capacity input on each ticket type to cap how many can be sold of that type."
msgstr "Afficher une entrée Capacité sur chaque type de billet pour limiter le nombre de billets de ce type qui peuvent être vendus."

#: src/Admin/manage-event/EventTickets.js:2469
msgid "Multiple pricing periods"
msgstr "Périodes de tarification multiples"

#: src/Admin/manage-event/EventTickets.js:2473
msgid "Enable time-based pricing with multiple sale periods (e.g. early bird, regular, late). When off, a single flat price applies for the whole sale window."
msgstr "Activez la tarification basée sur le temps avec plusieurs périodes de vente (par exemple, tarif précoce, régulier, tardif). Lorsque cette option est désactivée, un prix unique s'applique à toute la fenêtre de vente."

#: src/Admin/manage-event/EventTickets.js:2486
msgid "Seats per ticket"
msgstr "Sièges par billet"

#: src/Admin/manage-event/EventTickets.js:2490
msgid "Show a Seats input on each ticket type to let one ticket consume more than one capacity slot (e.g. couples or +1 tickets). When off, every ticket counts as 1 seat."
msgstr "Afficher une entrée Sièges sur chaque type de billet pour permettre à un billet de consommer plus d'une place de capacité (par exemple, couples ou billets +1). Lorsque cette option est désactivée, chaque billet compte comme 1 siège."

#: src/Admin/manage-event/EventTickets.js:2503
msgid "Per-ticket-type minimum activities"
msgstr "Activités minimales par type de billet"

#: src/Admin/manage-event/EventTickets.js:2507
msgid "Show a Min. activities input on each ticket type to require more activities than the event-wide minimum (it only ever raises it). When off, every ticket type uses the event-wide minimum."
msgstr "Afficher une entrée Min. activités sur chaque type de billet pour exiger plus d'activités que le minimum au niveau de l'événement (cela ne fait que l'augmenter). Lorsque cette option est désactivée, chaque type de billet utilise le minimum au niveau de l'événement."

#: src/Admin/manage-event/EventTickets.js:2523
msgid "Per-ticket-type end date"
msgstr "Date de fin par type de billet"

#: src/Admin/manage-event/EventTickets.js:2527
msgid "Show a date/time input on each ticket type to stop selling it after a fixed date, regardless of remaining capacity."
msgstr "Afficher une entrée date/heure sur chaque type de billet pour arrêter sa vente après une date fixe, indépendamment de la capacité restante."

#: src/Admin/manage-event/EventTickets.js:2540
msgid "Activity collaborator discount"
msgstr "Remise collaborateur d'activité"

#: src/Admin/manage-event/EventTickets.js:2544
msgid "Allow a discounted price on each activity option for participants invited by a collaborator linked to that activity. Adds a second price column to the activity options table and enables Manage Invitations."
msgstr "Autoriser un prix réduit sur chaque option d'activité pour les participants invités par un collaborateur lié à cette activité. Ajoute une deuxième colonne de prix au tableau des options d'activité et active Gérer les invitations."

#: src/Admin/manage-event/EventTickets.js:2559
msgid "Per-period pricing"
msgstr "Tarification par période"

#: src/Admin/manage-event/EventTickets.js:2563
msgid "Price every activity option per sale period instead of a single flat price. The Pricing column in the activity options table becomes one input per sale period. Requires sale periods to be defined."
msgstr "Tarifiez chaque option d'activité par période de vente au lieu d'un prix unique. La colonne Tarification du tableau des options d'activité devient une entrée par période de vente. Nécessite que les périodes de vente soient définies."

#: src/Admin/manage-event/EventTickets.js:2582
msgid "Switching back to simple ticketing will remove all ticket types, sale periods, and prices. Continue?"
msgstr "Le passage à la billetterie simple supprimera tous les types de billets, les périodes de vente et les tarifs. Continuer ?"

#: src/Admin/manage-event/EventTickets.js:2594
msgid "Switch to simple ticketing"
msgstr "Passer à la billetterie simple"

