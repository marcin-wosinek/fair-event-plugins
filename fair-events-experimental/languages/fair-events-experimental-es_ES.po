#: src/Admin/manage-event/EventTickets.js:1898
msgid "Minimum number of activities"
msgstr "Número mínimo de actividades"

#: src/Admin/manage-event/EventTickets.js:1902
msgid "Participants must select at least this many activities to sign up. Set to 0 to disable."
msgstr "Los participantes deben seleccionar al menos esta cantidad de actividades para registrarse. Establece 0 para desactivar."

#: src/Admin/manage-event/EventTickets.js:1924
msgid "Add selectable activity options (checkboxes) shown to participants at signup. Each option has its own price added on top of the base price."
msgstr "Añade opciones de actividad seleccionables (casillas de verificación) que se muestran a los participantes en el registro. Cada opción tiene su propio precio añadido al precio base."

#: src/Admin/manage-event/EventTickets.js:1941
msgid "Price (EUR)"
msgstr "Precio (EUR)"

#: src/Admin/manage-event/EventTickets.js:1948
msgid "Discounted price (EUR)"
msgstr "Precio con descuento (EUR)"

#: src/Admin/manage-event/EventTickets.js:1961
msgid "Collaborator(s)"
msgstr "Colaborador(es)"

#: src/Admin/manage-event/EventTickets.js:1987
msgid "Activity name"
msgstr "Nombre de la actividad"

#: src/Admin/manage-event/EventTickets.js:2017
#: src/Admin/manage-event/EventTickets.js:2022
msgid "Short name"
msgstr "Nombre corto"

#: src/Admin/manage-event/EventTickets.js:2120
msgid "No discount"
msgstr "Sin descuento"

#: src/Admin/manage-event/EventTickets.js:2249
msgid "Add participants"
msgstr "Añadir participantes"

#: src/Admin/manage-event/EventTickets.js:2306
msgid "+ Add Option"
msgstr "+ Añadir opción"

#: src/Admin/manage-event/EventTickets.js:2316
msgid "Settings"
msgstr "Ajustes"

#: src/Admin/manage-event/EventTickets.js:2321
msgid "Continues pricing period"
msgstr "Período de precios continuo"

#: src/Admin/manage-event/EventTickets.js:2334
msgid "Unlimited tickets in pricing period"
msgstr "Entradas ilimitadas en el período de precios"

#: src/Admin/manage-event/EventTickets.js:2350
msgid "Per-ticket-type capacity"
msgstr "Capacidad por tipo de entrada"

#: src/Admin/manage-event/EventTickets.js:2354
msgid "Show a Capacity input on each ticket type to cap how many can be sold of that type."
msgstr "Muestra un campo de capacidad en cada tipo de entrada para limitar cuántos se pueden vender de ese tipo."

#: src/Admin/manage-event/EventTickets.js:2367
msgid "Multiple pricing periods"
msgstr "Períodos de precios múltiples"

#: src/Admin/manage-event/EventTickets.js:2371
msgid "Enable time-based pricing with multiple sale periods (e.g. early bird, regular, late). When off, a single flat price applies for the whole sale window."
msgstr "Habilita precios basados en el tiempo con múltiples períodos de venta (p. ej. preventa, regular, última hora). Cuando está desactivado, se aplica un precio único para toda la ventana de venta."

#: src/Admin/manage-event/EventTickets.js:2384
msgid "Seats per ticket"
msgstr "Asientos por entrada"

#: src/Admin/manage-event/EventTickets.js:2388
msgid "Show a Seats input on each ticket type to let one ticket consume more than one capacity slot (e.g. couples or +1 tickets). When off, every ticket counts as 1 seat."
msgstr "Muestra un campo de asientos en cada tipo de entrada para permitir que una entrada consuma más de un espacio de capacidad (p. ej. parejas o entradas +1). Cuando está desactivado, cada entrada cuenta como 1 asiento."

#: src/Admin/manage-event/EventTickets.js:2401
msgid "Per-ticket-type minimum activities"
msgstr "Actividades mínimas por tipo de entrada"

#: src/Admin/manage-event/EventTickets.js:2405
msgid "Show a Min. activities input on each ticket type to require more activities than the event-wide minimum (it only ever raises it). When off, every ticket type uses the event-wide minimum."
msgstr "Muestra un campo de actividades mín. en cada tipo de entrada para requerir más actividades que el mínimo de todo el evento (solo lo aumenta). Cuando está desactivado, cada tipo de entrada utiliza el mínimo de todo el evento."

#: src/Admin/manage-event/EventTickets.js:2421
msgid "Per-ticket-type end date"
msgstr "Fecha de fin por tipo de entrada"

#: src/Admin/manage-event/EventTickets.js:2425
msgid "Show a date/time input on each ticket type to stop selling it after a fixed date, regardless of remaining capacity."
msgstr "Muestra un campo de fecha/hora en cada tipo de entrada para dejar de venderlo después de una fecha fija, independientemente de la capacidad restante."

#: src/Admin/manage-event/EventTickets.js:2438
msgid "Activity collaborator discount"
msgstr "Descuento de colaborador de actividad"

#: src/Admin/manage-event/EventTickets.js:2442
msgid "Allow a discounted price on each activity option for participants invited by a collaborator linked to that activity. Adds a second price column to the activity options table and enables Manage Invitations."
msgstr "Permite un precio reducido en cada opción de actividad para participantes invitados por un colaborador vinculado a esa actividad. Añade una segunda columna de precio a la tabla de opciones de actividad y habilita Gestionar invitaciones."

#: src/Admin/manage-event/EventTickets.js:2457
msgid "Per-period pricing"
msgstr "Precios por período"

#: src/Admin/manage-event/EventTickets.js:2461
msgid "Price every activity option per sale period instead of a single flat price. The Pricing column in the activity options table becomes one input per sale period. Requires sale periods to be defined."
msgstr "Establece el precio de cada opción de actividad por período de venta en lugar de un precio único. La columna Precios en la tabla de opciones de actividad se convierte en una entrada por período de venta. Requiere que se definan períodos de venta."

#: src/Admin/manage-event/EventTickets.js:2480
msgid "Switching back to simple ticketing will remove all ticket types, sale periods, and prices. Continue?"
msgstr "¿Cambiar a venta de entradas simple eliminará todos los tipos de entrada, períodos de venta y precios. ¿Continuar?"

#: src/Admin/manage-event/EventTickets.js:2492
msgid "Switch to simple ticketing"
msgstr "Cambiar a venta de entradas simple"

