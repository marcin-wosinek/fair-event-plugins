{
	"permissions": {
		"allow": ["Bash(vendor/bin/phpcs *)"]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-generated-files.sh\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-edited-file.sh\""
					}
				]
			}
		]
	},
	"enabledPlugins": {
		"frontend-design@claude-plugins-official": true
	}
}
