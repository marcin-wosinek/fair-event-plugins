{
	"name": "fair-event-plugins/fair-payment",
	"description": "Simple payment block for WordPress",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"FairPayment\\": "src/"
		}
	},
	"repositories": [
		{
			"type": "path",
			"url": "../fair-events-shared/php",
			"options": {
				"symlink": false
			}
		}
	],
	"require": {
		"php": ">=7.4",
		"mollie/mollie-api-php": "^2.0",
		"fair-events/shared": "^0.1"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0",
		"squizlabs/php_codesniffer": "^3.7",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"scripts": {
		"test": "phpunit",
		"phpcs": "phpcs",
		"phpcbf": "phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"platform": {
			"php": "8.2"
		}
	}
}
