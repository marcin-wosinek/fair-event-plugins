.DS_Store
.vscode/*
!vendor/autoload.php
!.vscode/launch.json
!.vscode/settings.json
.vscode
# .claude is tracked (hooks, commands, settings.json) — only local state is ignored
.claude/settings.local.json
.claude/scheduled_tasks.lock
vendor/

# Plugin dependencies and build artifacts
*/vendor/*
*/node_modules/*
*/build/*
node_modules
dist

# Playwright test results and reports
playwright-report/
test-results/
*/playwright-report/
*/test-results/
*/tests/screenshots/*.png
*/.env

# Local deploy config (real values); template `.deploy/example.env` is committed
.deploy/*.env
!.deploy/example.env

# Temporary files
*.tmp
*.log
*.cache

# Release scripts (local SVN checkouts)
*/svn/

# Generated GlotPress-import files (scripts/translation/export-for-wporg.js)
*/languages/wporg-import/
.vim/coc-settings.json
deployment-config.txt
fair-platform-deployment-config.txt
.env
